[
	{
		"id": "core-content",
		"file": "reference/always/core-content.md",
		"load": "always",
		"when": "Always load for any selected MDX file with added content lines."
	},
	{
		"id": "links",
		"file": "reference/conditional/links.md",
		"load": "conditional",
		"when": "Patch contains Markdown links, href=, http, root-relative paths, or anchors."
	},
	{
		"id": "code-blocks",

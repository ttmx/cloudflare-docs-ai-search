---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import ModelCatalog from "~/components/ModelCatalog.tsx";
import { getLegacyModels, toModelCardData } from "~/util/model-resolver";
import { Aside } from "~/components";

const models = (await getLegacyModels()).map(toModelCardData);
---

<StarlightPage
	frontmatter={{ title: "Workers AI Models", tableOfContents: false }}
>
	<Aside
		type="tip"
		title="Looking for more models, including external providers?"
	>
		Check out the <a href="/ai/models/">unified AI model catalog</a>.
	</Aside>
	<ModelCatalog models={models} basePath="/workers-ai/models" client:load />
</StarlightPage>

<style>
	:root {
		--sl-content-width: 1350px !important;
	}
</style>

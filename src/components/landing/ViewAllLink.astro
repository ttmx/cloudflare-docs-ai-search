---
import RightArrow from "./RightArrow.astro";

interface Props {
	href: string;
	class?: string;
}

const { href, class: className = "" } = Astro.props;
---

<a
	href={href}
	class:list={[
		"group text-accent-100 decoration-accent-100/40 hidden shrink-0 items-center gap-1.5 text-sm font-medium underline-offset-4 hover:underline md:inline-flex",
		className,
	]}
>
	<slot />
	<RightArrow
		variant="chevron"
		size={12}
		strokeWidth={1.2}
		class="transition-transform duration-150 group-hover:translate-x-0.5"
	/>
</a>

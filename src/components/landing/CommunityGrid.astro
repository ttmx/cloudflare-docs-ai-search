---
import CornerMarks from "./CornerMarks.astro";
import SectionHeading from "./SectionHeading.astro";

const cards = [
	{
		label: "Community",
		heading: "Join the conversation",
		desc: "Share ideas, answers, and code with the Cloudflare community.",
		links: [
			{ label: "Discord", href: "https://discord.cloudflare.com/" },
			{ label: "X", href: "https://x.com/cloudflare" },
			{ label: "Forum", href: "https://community.cloudflare.com/" },
		],
	},
	{
		label: "Open Source",
		heading: "View the source",
		desc: "Cloudflare contributes to the open-source ecosystem in a variety of ways, including:",
		links: [
			{ label: "GitHub", href: "https://github.com/cloudflare" },
			{ label: "Sponsors", href: "https://github.com/sponsors/cloudflare" },
			{ label: "Style guide", href: "/style-guide/" },
		],
	},
	{
		label: "Blog",
		heading: "Read the latest",
		desc: "Get the latest news on Cloudflare products, technologies, and culture.",
		links: [
			{ label: "blog.cloudflare.com", href: "https://blog.cloudflare.com/" },
		],
	},
];
---

<section
	id="community"
	class="pt-10 pb-10 lg:pt-14 lg:pb-12"
	aria-labelledby="community-heading"
>
	<div class="mb-6 sm:mb-8">
		<SectionHeading id="community-heading" class="mb-2">
			Connect with Cloudflare
		</SectionHeading>
		<p
			class="text-foreground-muted max-w-[600px] text-sm leading-relaxed text-pretty md:text-lg"
		>
			Find community, read the blog, and explore open source projects.
		</p>
	</div>

	<div
		class="border-border-100 bg-border-100 relative grid grid-cols-1 gap-px overflow-visible border md:grid-cols-3"
	>
		<CornerMarks />

		{
			cards.map((card) => (
				<div class="community-card bg-background flex flex-col p-6">
					<span class="text-accent-100 font-mono text-xs tracking-widest uppercase">
						{card.label}
					</span>
					<h3 class="text-foreground mt-3 mb-2 text-base leading-snug font-medium md:text-lg">
						{card.heading}
					</h3>
					<p class="text-foreground-muted mb-6 flex-1 text-sm leading-relaxed md:text-base">
						{card.desc}
					</p>

					<div class="flex flex-wrap items-center gap-x-4 gap-y-2">
						{card.links.map((link) => (
							<a
								href={link.href}
								class="text-foreground-muted inline-flex w-fit items-center text-sm font-medium underline-offset-4 hover:underline"
							>
								{link.label}
							</a>
						))}
					</div>
				</div>
			))
		}
	</div>
</section>

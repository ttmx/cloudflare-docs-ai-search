---
import { Icon } from "@astrojs/starlight/components";
import { stagger } from "./constants";
import Button from "./Button.astro";
import CopyPromptButton from "./CopyPromptButton.astro";
---

<section id="hero" class="pb-12 md:pt-6 lg:pb-16">
	<h1
		class={`text-[clamp(2.75rem,5vw,3.5rem)] font-medium text-balance mb-4 text-foreground ${stagger(0.05)}`}
	>
		Cloudflare Developer Docs
	</h1>

	<p
		class={`text-base text-pretty max-w-[480px] leading-relaxed mb-6 sm:text-lg sm:mb-8 text-foreground-muted ${stagger(0.1)}`}
	>
		Explore guides and tutorials to start building on Cloudflare's platform
	</p>

	<div class={`flex flex-wrap items-center gap-x-3 gap-y-3 ${stagger(0.16)}`}>
		<Button href="/fundamentals/get-started/" variant="primary" size="md">
			<span class="inline-flex items-center gap-2 text-base font-medium">
				Get started
				<Icon name="right-arrow" size="1rem" />
			</span>
		</Button>

		<CopyPromptButton tooltip="Sets up your AI agent for Cloudflare" />
	</div>
</section>

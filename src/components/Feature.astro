---
import { Icon } from "@astrojs/starlight/components";

interface Props {
	header: string;
	href: string;
	cta?: string;
}

const { header, href, cta } = Astro.props;

const title = cta ?? `Use ${header}`;
---

<div class="feature mb-7 border-t border-t-[var(--color-cl1-gray-8)] pt-6">
	<h3
		class="m-0 mb-2 text-[1.3125rem] leading-[1.3] font-bold tracking-[-0.02em]"
	>
		{header}
	</h3>
	<div
		class="feature-description mb-3 text-base leading-[1.65] text-[var(--sl-color-text)]"
	>
		<slot />
	</div>
	<a
		href={href}
		class="inline-flex items-center gap-1.5 border-b-2 border-b-[var(--color-cl1-brand-orange)] pb-px text-sm font-semibold text-[var(--sl-color-white)] no-underline transition-[border-color] duration-200 ease-in-out hover:border-b-[var(--sl-color-white)]"
	>
		{title}
		<Icon name="right-arrow" size="0.875rem" />
	</a>
</div>

<style>
	/* First feature in a consecutive group — no top divider */
	:global(.sl-markdown-content > .feature:not(.feature + .feature)) {
		border-top: none;
	}

	/* Reset paragraph margins inside the slot content */
	.feature-description :global(p) {
		margin: 0;
	}

	.feature-description :global(p + p) {
		margin-top: 0.375rem;
	}

	/* Inline links in description inherit the muted color, accent on hover */
	.feature-description :global(a) {
		color: var(--sl-color-text-accent);
		text-decoration: underline;
		text-decoration-color: transparent;
		text-underline-offset: 2px;
		transition: text-decoration-color 0.15s;
	}

	.feature-description :global(a:hover) {
		text-decoration-color: currentColor;
	}
</style>

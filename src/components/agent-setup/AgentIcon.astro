---
interface Props {
	icon: string;
	name: string;
	size?: number;
}

const { icon, name, size = 36 } = Astro.props;
const lightSrc = `/icons/agents/${icon}/light.svg`;
const darkSrc = `/icons/agents/${icon}/dark.svg`;
---

<span
	class="agent-setup-icon-wrap"
	style={`width: ${size}px; height: ${size}px; flex-shrink: 0;`}
>
	<img
		src={lightSrc}
		alt={`${name} icon`}
		width={size}
		height={size}
		class="agent-icon-light"
	/>
	<img
		src={darkSrc}
		alt={`${name} icon`}
		width={size}
		height={size}
		class="agent-icon-dark"
	/>
</span>

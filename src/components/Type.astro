---
import { z } from "astro/zod";

type Props = z.infer<typeof props>;

const props = z
	.object({
		text: z.string(),
	})
	.strict();

const { text } = props.parse(Astro.props);
---

<code
	class="inline-flex items-center rounded-md border border-[color:var(--color-table-fill)] bg-[var(--sl-color-gray-6)] px-1.5 py-0.5 text-[0.75rem] leading-none font-semibold"
>
	{text}
</code>

---
import { Icon as AstroIcon } from "astro-icon/components";

const policies = [
	{ label: "DNS", href: "/cloudflare-one/traffic-policies/dns-policies/" },
	{ label: "HTTP", href: "/cloudflare-one/traffic-policies/http-policies/" },
	{
		label: "Network",
		href: "/cloudflare-one/traffic-policies/network-policies/",
	},
];

const logsHref = "/cloudflare-one/insights/logs/dashboard-logs/gateway-logs/";
---

<figure
	class="vpc-overview-diagram not-content"
	aria-label="Workers VPC integrations across Cloudflare Tunnel, Cloudflare Mesh, and Cloudflare WAN"
>
	<div class="diagram">
		<div class="row worker-row">
			<div class="node-card worker-card">
				<div class="node-header">
					<span class="node-icon worker-icon" aria-hidden="true"
						><AstroIcon name="workers" /></span
					>
					<a class="node-title" href="/workers/">Worker</a>
				</div>
				<p class="node-caption">
					Bind via <a
						class="inline-pill workers-vpc-pill"
						href="/workers-vpc/configuration/vpc-services/"
						><code>vpc_services</code></a
					>
					<span class="caption-separator">or</span>
					<a
						class="inline-pill workers-vpc-pill"
						href="/workers-vpc/configuration/vpc-networks/"
						><code>vpc_networks</code></a
					>
				</p>
			</div>
		</div>

		<div class="row on-ramps-row">
			<div class="node-card tunnel-card">
				<div class="node-header">
					<span class="node-icon tunnel-icon" aria-hidden="true"
						><AstroIcon name="tunnel" /></span
					>
					<a class="node-title" href="/tunnel/">Cloudflare Tunnel</a>
				</div>
				<p class="node-caption">
					Reach private applications or networks through <code>cloudflared</code
					>
				</p>
			</div>

			<div class="node-card mesh-card">
				<div class="node-header">
					<span class="node-icon mesh-icon" aria-hidden="true"
						><AstroIcon name="cloudflare-mesh" /></span
					>
					<a
						class="node-title"
						href="/cloudflare-one/networks/connectors/cloudflare-mesh/"
						>Cloudflare Mesh</a
					>
				</div>
				<p class="node-caption">
					Reach the full account through <code>cf1:network</code>
				</p>
			</div>

			<div class="node-card wan-card">
				<div class="node-header">
					<span class="node-icon wan-icon" aria-hidden="true"
						><AstroIcon name="cloudflare-wan" /></span
					>
					<a class="node-title" href="/cloudflare-wan/">Cloudflare WAN</a>
				</div>
				<p class="node-caption">
					Reach destinations through GRE, IPsec, or CNI on-ramps
				</p>
			</div>
		</div>

		<div class="row gateway-row">
			<div class="node-card gateway-card">
				<div class="node-header">
					<span class="node-icon gateway-icon" aria-hidden="true"
						><AstroIcon name="gateway" /></span
					>
					<a class="node-title" href="/cloudflare-one/traffic-policies/"
						>Cloudflare Gateway</a
					>
				</div>
				<p class="node-caption">
					Mesh and WAN traffic flows through Gateway, with policies enforced and
					traffic <a class="logs-link" href={logsHref}>logged</a>.
				</p>
				<div class="pill-row">
					{
						policies.map((p) => (
							<a class="policy-pill" href={p.href}>
								{p.label}
							</a>
						))
					}
				</div>
			</div>
		</div>

		<div class="row destinations-row">
			<div class="destination-card private-card">
				<div class="destination-header">
					<span class="destination-dot private-dot" aria-hidden="true"></span>
					<span class="destination-title">Private services</span>
				</div>
				<p class="destination-caption">
					APIs, databases, hosts in your network — reachable via any on-ramp
				</p>
			</div>

			<div class="destination-card public-card">
				<div class="destination-header">
					<span class="destination-dot public-dot" aria-hidden="true"></span>
					<span class="destination-title">Public Internet</span>
				</div>
				<p class="destination-caption">Reachable via Mesh or WAN</p>
			</div>
		</div>
	</div>
</figure>

<style>
	.vpc-overview-diagram {
		--map-bg: light-dark(#fafafa, #0f0f10);
		--map-card: light-dark(#ffffff, #171719);
		--map-elevated: light-dark(#fafafa, #111113);
		--map-overlay: light-dark(#f5f5f5, #222226);
		--map-line: light-dark(rgb(0 0 0 / 12%), rgb(255 255 255 / 14%));
		--map-text: light-dark(#171717, #f5f5f5);
		--map-strong: light-dark(#525252, #a3a3a3);
		--map-subtle: light-dark(#737373, #d4d4d4);
		--map-caption: light-dark(#737373, #a3a3a3);
		--map-brand: #f6821f;
		--map-tunnel: light-dark(#0891b2, #67e8f9);
		--map-mesh: light-dark(#7c3aed, #a78bfa);
		--map-wan: light-dark(#db2777, #f9a8d4);
		--map-gateway: light-dark(#0ea5e9, #38bdf8);
		--map-private: light-dark(#10b981, #34d399);
		--map-public: light-dark(#ea580c, #fb923c);

		display: flex;
		flex-direction: column;
		gap: 12px;
		margin: 1.5rem 0;
		padding: 22px;
		border: 1px solid var(--map-line);
		border-radius: 12px;
		background:
			radial-gradient(circle, var(--map-line) 1px, transparent 1px),
			var(--map-bg);
		background-size: 14px 14px;
		font-family: "Inter Variable", ui-sans-serif, system-ui, sans-serif;
		font-feature-settings: "cv02", "cv03", "cv04", "calt";
		-webkit-font-smoothing: antialiased;
		letter-spacing: -0.01em;
	}

	.vpc-overview-diagram a {
		color: inherit;
		text-decoration: none;
	}

	.diagram {
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	.row {
		position: relative;
		display: grid;
		gap: 16px;
		align-items: stretch;
	}

	.row::before {
		content: "";
		position: absolute;
		top: -14px;
		left: 50%;
		width: 2px;
		height: 12px;
		background: var(--map-line);
	}

	.row:first-child::before {
		display: none;
	}

	.worker-row {
		grid-template-columns: minmax(0, 1fr);
		justify-items: center;
	}

	.worker-row .node-card {
		max-width: 480px;
		width: 100%;
	}

	.on-ramps-row {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.gateway-row {
		grid-template-columns: minmax(0, 1fr);
		justify-items: center;
	}

	.gateway-row .node-card {
		max-width: 540px;
		width: 100%;
	}

	.destinations-row {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.node-card {
		display: flex;
		flex-direction: column;
		gap: 8px;
		padding: 12px 14px;
		border: 1px solid var(--map-line);
		border-radius: 10px;
		background: var(--map-card);
		box-shadow: 0 5px 14px rgb(0 0 0 / 7%);
		color: var(--map-text);
	}

	.node-header {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
	}

	.node-title {
		min-width: 0;
		color: var(--map-text);
		font-size: 14px;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	a.node-title {
		transition: color 150ms ease;
	}

	a.node-title:hover {
		color: var(--map-brand);
	}

	.node-icon {
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 7px;
		font-size: 14px;
		font-weight: 600;
	}

	.node-icon :global(svg) {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	.worker-icon {
		background: color-mix(in srgb, var(--map-brand) 14%, transparent);
		color: var(--map-brand);
	}

	.tunnel-icon {
		background: color-mix(in srgb, var(--map-tunnel) 14%, transparent);
		color: var(--map-tunnel);
	}

	.mesh-icon {
		background: color-mix(in srgb, var(--map-mesh) 14%, transparent);
		color: var(--map-mesh);
	}

	.wan-icon {
		background: color-mix(in srgb, var(--map-wan) 14%, transparent);
		color: var(--map-wan);
	}

	.gateway-icon {
		background: color-mix(in srgb, var(--map-gateway) 14%, transparent);
		color: var(--map-gateway);
	}

	.node-caption {
		margin: 0;
		color: var(--map-caption);
		font-size: 12px;
		line-height: 1.5;
		text-align: center;
	}

	.on-ramps-row .node-caption {
		min-height: calc(2 * 12px * 1.5);
	}

	.node-caption code {
		display: inline;
		padding: 1px 6px;
		border: 1px solid var(--map-line);
		border-radius: 5px;
		background: var(--map-elevated);
		color: var(--map-text);
		font-family:
			"Paper Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 11px;
		white-space: nowrap;
	}

	.caption-separator {
		color: var(--map-subtle);
		font-size: 11px;
	}

	.inline-pill {
		display: inline;
		padding: 1px 6px;
		border-radius: 5px;
		transition:
			border-color 150ms ease,
			background-color 150ms ease;
		white-space: nowrap;
	}

	.workers-vpc-pill {
		border: 1px solid color-mix(in srgb, var(--map-brand) 35%, var(--map-line));
		background: color-mix(in srgb, var(--map-brand) 6%, var(--map-card));
	}

	.workers-vpc-pill:hover {
		border-color: var(--map-brand);
		background: color-mix(in srgb, var(--map-brand) 12%, var(--map-card));
	}

	.workers-vpc-pill code {
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--map-brand);
		font-family:
			"Paper Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 11px;
		white-space: nowrap;
	}

	.mesh-pill {
		border: 1px solid color-mix(in srgb, var(--map-mesh) 35%, var(--map-line));
		background: color-mix(in srgb, var(--map-mesh) 6%, var(--map-card));
	}

	.mesh-pill:hover {
		border-color: var(--map-mesh);
		background: color-mix(in srgb, var(--map-mesh) 12%, var(--map-card));
	}

	.mesh-pill code {
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--map-mesh);
		font-family:
			"Paper Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 11px;
		white-space: nowrap;
	}

	.pill-row {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 6px;
	}

	.policy-pill {
		display: inline-flex;
		align-items: center;
		padding: 4px 10px;
		border: 1px solid
			color-mix(in srgb, var(--map-gateway) 35%, var(--map-line));
		border-radius: 6px;
		background: color-mix(in srgb, var(--map-gateway) 6%, var(--map-card));
		color: var(--map-text);
		font-size: 11px;
		font-weight: 500;
		transition:
			border-color 150ms ease,
			background-color 150ms ease;
	}

	.policy-pill:hover {
		border-color: var(--map-gateway);
		background: color-mix(in srgb, var(--map-gateway) 14%, var(--map-card));
	}

	.destination-card {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 12px 14px;
		border: 1px solid var(--map-line);
		border-radius: 10px;
		background: var(--map-card);
		box-shadow: 0 5px 14px rgb(0 0 0 / 7%);
		color: var(--map-text);
	}

	.destination-header {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
	}

	.destination-title {
		color: var(--map-text);
		font-size: 13px;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.destination-dot {
		width: 10px;
		height: 10px;
		border-radius: 9999px;
		flex: 0 0 auto;
	}

	.private-dot {
		background: var(--map-private);
		box-shadow: 0 0 0 3px
			color-mix(in srgb, var(--map-private) 18%, transparent);
	}

	.public-dot {
		background: var(--map-public);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--map-public) 18%, transparent);
	}

	.destination-caption {
		margin: 0;
		color: var(--map-caption);
		font-size: 12px;
		line-height: 1.5;
		text-align: center;
	}

	.logs-link {
		color: var(--map-caption);
		text-decoration: underline;
		text-decoration-color: color-mix(
			in srgb,
			var(--map-caption) 35%,
			transparent
		);
		text-underline-offset: 2px;
		transition:
			color 150ms ease,
			text-decoration-color 150ms ease;
	}

	.logs-link:hover {
		color: var(--map-text);
		text-decoration-color: var(--map-gateway);
	}

	@media (max-width: 52rem) {
		.on-ramps-row,
		.destinations-row {
			grid-template-columns: minmax(0, 1fr);
		}

		.row::before {
			height: 14px;
			top: -16px;
		}
	}
</style>

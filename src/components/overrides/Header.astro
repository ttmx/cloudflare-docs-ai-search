---
import LanguageSelect from "@astrojs/starlight/components/LanguageSelect.astro";
import SiteTitle from "@astrojs/starlight/components/SiteTitle.astro";
import ThemeSelect from "@astrojs/starlight/components/ThemeSelect.astro";

import HeaderDropdowns from "../HeaderDropdowns.tsx";
import AgentDirective from "../AgentDirective.astro";
---

<AgentDirective />

<div class="header-inner">
	<div class="header-start">
		<SiteTitle />
	</div>
	<div class="header-end">
		<div id="docsearch">
			<button type="button" class="ai-search-button" aria-label="Search">
				<svg
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<circle cx="11" cy="11" r="8"></circle>
					<path d="m21 21-4.3-4.3"></path>
				</svg>
				<span class="ai-search-button-label">Search</span>
				<kbd class="ai-search-button-key">Ctrl K</kbd>
			</button>
			<!--
				Search + indexing live in the standalone `devdocs-ai-search-indexer`
				worker. The docs worker proxies /api/ai-search/* to it via a service
				binding, so this stays a same-origin relative URL.
			-->
			<search-modal-snippet
				api-url="/api/ai-search"
				placeholder="Search documentation..."
				max-results="50"
				max-render-results="10"
				group-by="product"
				show-url="false"></search-modal-snippet>
		</div>
		<div id="right-group">
			<HeaderDropdowns client:idle />
			<div class="header-divider" role="separator"></div>
			<a
				id="header-login-button"
				href="https://dash.cloudflare.com/"
				class="header-login"
			>
				Log in
			</a>
			<ThemeSelect />
			<LanguageSelect />
		</div>
	</div>
</div>

<style>
	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 100%;
		gap: 1rem;
	}

	.header-start {
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}

	.header-end {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.header-divider {
		width: 1px;
		height: 1rem;
		background-color: var(--color-header-line);
		margin-inline: 0.375rem;
		flex-shrink: 0;
	}

	/*
	 * Header CTA — mirrors the visual identity of the landing page's
	 * "Get started" button (src/components/landing/Button.astro, primary).
	 *
	 * Colour values match the landing-root values of `--color-accent-100`
	 * (#ff5e1f light / #ff4801 dark) and `--color-light-foreground`
	 * (#fffbf5). They're hard-coded here — including the per-theme accent —
	 * because those tokens are only defined inside `.landing-root`;
	 * starlight-tailwind sets `--color-accent-100` to indigo site-wide,
	 * which would render the header CTA blue.
	 *
	 * Press feel (opacity hover, translate-y + scale on active, accent
	 * focus ring) replicates Button.astro without the inset before/after
	 * pseudo-element overlays — those are a marketing-grade flourish that
	 * reads as noise at header scale.
	 */
	.header-login {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2.25rem;
		padding: 0 1rem;
		border-radius: 9999px;
		font-size: 0.875rem;
		font-weight: 500;
		line-height: 1;
		white-space: nowrap;
		text-decoration: none;
		background-color: #ff5e1f;
		color: #fffbf5;
		transform: translateZ(
			0
		); /* promote to its own layer for crisp transforms */
		transition:
			opacity 160ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
			transform 160ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
			box-shadow 160ms ease-out;
	}

	.header-login:hover {
		color: #fffbf5;
		opacity: 0.95;
	}

	.header-login:focus-visible {
		outline: none;
		box-shadow: 0 0 0 3px rgb(255 94 31 / 0.5);
	}

	.header-login:active {
		transform: translateY(1px) scale(0.98);
		transition-duration: 60ms;
	}

	/* Match the landing "Get started" accent in dark mode (#ff4801). */
	:root[data-theme="dark"] .header-login {
		background-color: #ff4801;
	}

	:root[data-theme="dark"] .header-login:focus-visible {
		box-shadow: 0 0 0 3px rgb(255 72 1 / 0.5);
	}

	@media (prefers-reduced-motion: reduce) {
		.header-login {
			transition: none;
		}
		.header-login:active {
			transform: none;
		}
	}

	:global(.site-title) {
		gap: 0.5rem;
		min-width: fit-content;
		overflow: visible;
	}

	:global(.site-title span) {
		color: var(--color-cl1-black);
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	:root[data-theme="dark"] :global(.site-title span) {
		color: var(--color-cl1-white);
	}

	:global(.site-title img) {
		height: 1.25rem;
	}

	:global(starlight-theme-select > label > select) {
		line-height: 1.25rem;
		margin: 1px;
		color: var(--color-header-text-subtle);
	}

	:global(
		starlight-theme-select > label > select:focus,
		starlight-theme-select > label > select:focus-visible
	) {
		margin: 1px;
		outline-offset: -4px;
	}

	:global(starlight-theme-select > label > .label-icon) {
		left: 8%;
		color: var(--color-header-text-subtle);
	}

	:global(starlight-theme-select > label > .caret) {
		left: 75%;
	}

	#right-group {
		display: none;
		align-items: center;
		gap: 0.25rem;
	}

	@media screen and (min-width: 800px) {
		#right-group {
			display: flex;
		}

		#docsearch {
			width: 18rem;
		}
	}

	.ai-search-button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		width: 100%;
		height: 2.25rem;
		padding: 0 0.75rem;
		border: 1px solid var(--color-header-line);
		border-radius: 0.5rem;
		background: transparent;
		color: var(--color-header-text-subtle);
		font-size: 0.875rem;
		cursor: pointer;
		transition:
			color 150ms,
			background-color 150ms,
			border-color 150ms;
	}

	.ai-search-button:hover {
		background-color: var(--color-header-fill);
		color: var(--color-header-hover-text);
	}

	.ai-search-button-label {
		flex: 1;
		text-align: start;
	}

	.ai-search-button-key {
		font-size: 0.75rem;
		padding: 0.05rem 0.35rem;
		border: 1px solid var(--color-header-line);
		border-radius: 0.25rem;
		color: var(--color-header-text-subtle);
	}

	/* The modal renders itself; keep only the trigger button in header flow. */
	search-modal-snippet {
		display: contents;
		/* Render result icons (the worker maps item type -> a page/section SVG in
		   the `image` metadata) as a small Algolia-style leading glyph rather than
		   a full thumbnail. This custom property pierces the snippet's shadow DOM. */
		--search-snippet-result-image-size: 20px;

		/* Theme the snippet with the docs' own palette. These source tokens are
		   redefined under :root[data-theme="dark"], so mapping onto them makes the
		   snippet follow the site's light/dark toggle automatically. Custom
		   properties set on the host inherit across the snippet's shadow boundary
		   and override its built-in :host defaults. */
		--search-snippet-font-family: var(--sl-font);
		--search-snippet-background: var(--sl-color-bg);
		--search-snippet-surface: var(--sl-color-gray-7, var(--sl-color-gray-6));
		--search-snippet-hover-background: var(--sl-color-gray-6);
		--search-snippet-border-color: var(--sl-color-gray-5);
		--search-snippet-text-color: var(--sl-color-text);
		--search-snippet-text-secondary: var(--sl-color-gray-3);
		--search-snippet-text-description: var(--sl-color-gray-2);

		/* Cloudflare-orange accent, matching blog.cloudflare.com's snippet. */
		--search-snippet-primary-color: var(--color-cl1-brand-orange);
		--search-snippet-primary-hover: var(--color-cl1-orange-6);
		--search-snippet-focus-ring: rgb(246 130 31 / 0.25);
	}
</style>

<script>
	import { track } from "~/util/zaraz";
	import "@cloudflare/ai-search-snippet";

	document
		.querySelector("#header-login-button")
		?.addEventListener("click", () => {
			track("clicked header login button");
		});

	// The snippet modal opens on Cmd/Ctrl+K on its own; wire the header button
	// to open it too. Click tracking is handled by registerDocSearch(), which
	// listens on the #docsearch wrapper this button lives in.
	const searchButton =
		document.querySelector<HTMLButtonElement>(".ai-search-button");
	const searchModal = document.querySelector("search-modal-snippet") as
		| (HTMLElement & { open?: () => void })
		| null;
	searchButton?.addEventListener("click", () => searchModal?.open?.());
</script>

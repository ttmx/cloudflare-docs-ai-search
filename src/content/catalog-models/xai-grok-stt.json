	"metadata": {
		"Languages": "25 supported language codes (en, fr, de, ja, zh, ...)",
		"Audio Formats": "wav, mp3, ogg, opus, flac, aac, mp4, m4a, mkv (+ raw pcm/mulaw/alaw)",
